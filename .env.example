# 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 或直接设置系统环境变量

# 飞书应用凭证（从 https://open.feishu.cn/app 获取）
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 多维表格配置
BITABLE_APP_TOKEN=your_bitable_app_token
BITABLE_STORE_TABLE_ID=tbl_store
BITABLE_INSPECTION_TABLE_ID=tbl_inspection
BITABLE_CUSTOMER_TABLE_ID=tbl_customer
BITABLE_SALES_TABLE_ID=tbl_sales
BITABLE_PRODUCT_TABLE_ID=tbl_product
BITABLE_RECTIFICATION_TABLE_ID=tbl_rectification

# aily智能体配置（从 https://aily.feishu.cn 获取）
AILY_APP_ID=your_aily_app_id
AILY_APP_SECRET=your_aily_app_secret
AILY_AGENT_ID=your_aily_agent_id

# Flask密钥
SECRET_KEY=your_secret_key
