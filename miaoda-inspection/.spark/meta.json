{
  "app_id": "",
  "app_name": "雨虹门店巡检",
  "app_type": "full_stack",
  "runtime": "node",
  "entry": "server.js",
  "env": [
    { "key": "FEISHU_APP_ID", "value": "${FEISHU_APP_ID}", "env": "online" },
    { "key": "FEISHU_APP_SECRET", "value": "${FEISHU_APP_SECRET}", "env": "online" },
    { "key": "BITABLE_APP_TOKEN", "value": "${BITABLE_APP_TOKEN}", "env": "online" },
    { "key": "TABLE_STORE", "value": "${TABLE_STORE}", "env": "online" },
    { "key": "TABLE_INSPECTION", "value": "${TABLE_INSPECTION}", "env": "online" }
  ]
}
